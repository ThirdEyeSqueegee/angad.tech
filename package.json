{
  "name": "angad.tech",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --open",
    "build": "tsc && vite build",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives",
    "preview": "vite preview",
    "format": "prettier --write src/ *.json *.ts *.md *.html !package.json"
  },
  "dependencies": {
